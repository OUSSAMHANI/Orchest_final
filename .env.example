# =========================
# KAFKA CONFIGURATION
# =========================
KAFKA_BROKERS=["localhost:9092"]
KAFKA_TOPIC_TICKETS=gitlab-tickets
KAFKA_TOPIC_RESULTS=orchestrator-results
KAFKA_CONSUMER_GROUP=orchestrator-group
KAFKA_ENABLE_AUTO_COMMIT=true
KAFKA_AUTO_OFFSET_RESET=earliest

# Kafka Security (if needed - comment out if not used)
# KAFKA_SECURITY_PROTOCOL=SSL
# KAFKA_SASL_MECHANISM=PLAIN
# KAFKA_SASL_USERNAME=your-username
# KAFKA_SASL_PASSWORD=your-password

# =========================
# AGENT CONFIGURATION
# =========================
SPEC_AGENT_URL=http://localhost:8001
CODER_AGENT_URL=http://localhost:8002
TESTER_AGENT_URL=http://localhost:8003
REVIEWER_AGENT_URL=http://localhost:8004

AGENT_TIMEOUT=120
AGENT_MAX_RETRIES=3
AGENT_RETRY_BACKOFF=1.0
AGENT_RETRYABLE_ERRORS=["timeout","connection","rate_limit","503","429"]

# =========================
# ORCHESTRATOR CONFIGURATION
# =========================
MAX_RETRIES=3
MAX_REGENERATIONS=3
CONFIDENCE_THRESHOLD=0.7
STEP_TIMEOUT=300
RECURSION_LIMIT=100
DEAD_LETTER_ENABLED=true
DEAD_LETTER_TOPIC=orchestrator-dead-letter

# =========================
# WORKSPACE CONFIGURATION
# =========================
WORKSPACE_BASE_PATH=/workspaces
WORKSPACE_CLEANUP_ON_COMPLETE=true
WORKSPACE_CLEANUP_ON_FAILURE=false
WORKSPACE_CLEANUP_DELAY_SECONDS=3600
WORKSPACE_MAX_SIZE_MB=1024

# =========================
# GITLAB CONFIGURATION
# =========================
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=glpat-YOUR_ACTUAL_TOKEN_HERE
GITLAB_MERGE_REQUEST_TITLE_PREFIX=[AI]
GITLAB_MERGE_REQUEST_TARGET_BRANCH=main
GITLAB_AUTO_ASSIGN_REVIEWER=true

# =========================
# LLM CONFIGURATION
# =========================
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# ===== Groq =====
GROQ_API_KEY=gsk_YOUR_ACTUAL_GROQ_API_KEY_HERE

# ===== OpenAI (optional) =====
# OPENAI_API_KEY=sk-YOUR_OPENAI_KEY_HERE
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_ORGANIZATION=org-xxx

# ===== Anthropic (optional) =====
# ANTHROPIC_API_KEY=ant-YOUR_ANTHROPIC_KEY_HERE
# ANTHROPIC_API_VERSION=2023-06-01

# ===== Azure OpenAI (optional) =====
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your-azure-key
# AZURE_OPENAI_DEPLOYMENT=gpt-4
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ===== Local LLM (optional) =====
# LOCAL_LLM_URL=http://localhost:11434
# LOCAL_LLM_MODEL=llama2

# ===== Cohere (optional) =====
# COHERE_API_KEY=your-cohere-key
# COHERE_MODEL=command-r

# ===== Together AI (optional) =====
# TOGETHER_API_KEY=your-together-key
# TOGETHER_MODEL=meta-llama/Llama-3-8b-chat-hf

# LLM Request settings
LLM_REQUEST_TIMEOUT=60
LLM_MAX_RETRIES=3
LLM_RETRY_BACKOFF=1.0

# Cache LLM responses (for testing)
LLM_CACHE_ENABLED=false
LLM_CACHE_TTL_SECONDS=3600

# =========================
# LOGGING CONFIGURATION
# =========================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/orchestrator.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# =========================
# API CONFIGURATION
# =========================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false
CORS_ORIGINS=["*"]
API_RATE_LIMIT_REQUESTS=100

# =========================
# MONITORING CONFIGURATION
# =========================
ENABLE_METRICS=true
ENABLE_TRACING=false
METRICS_PORT=9090
SERVICE_NAME=orchestrator

# Tracing (optional)
# TRACING_ENDPOINT=http://localhost:4318

# =========================
# DEVELOPMENT CONFIGURATION
# =========================
DEBUG=false
MOCK_AGENTS=false
MOCK_GITLAB=false
SKIP_WORKSPACE_VALIDATION=false


SPEC_AGENT_LLM_PROVIDER=groq
SPEC_AGENT_LLM_MODEL=llama

# ── Google Gemini (REQUIRED) ─────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
MODEL_NAME=gemma-4-31b-it       # e.g. gemini-3-1-flash-lite


# ── Groq ─────────────────────────────────────────────────────────────────────
GROQ_MODEL=qwen/qwen3-32b

# ── OpenRouter ─────────────────────────────────────────────────────────────────────
OPEN_ROUTER_KEY=
OPEN_ROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free

# ── LM Studio (Local LLM) ────────────────────────────────────────────────────

# ────── Model tested ───────────────────────────────────                 ──────── Review ───────────────────────────────────────────────────────        ────────Provider──────────────────────────
#       qwen/qwen3-4b                                                       - Not Available yet 
#   qwen3.5-2b-claude-4.6-opus-reasoning-distilled@q4_k_m                   - Horrible at reasoning
#       qwen/qwen3-4b-2507                                                  - Not Available yet
#       qwen/qwen3-32b                                                      - Generate Fix : correct packages / working fix
#     qwen/qwen3.6-plus:free                                                - Generate Fix : correct packages /working fix / Correct conventions
#   google/gemma-4-31b-it:free                                              - Token used in debug phase : fast / coherent generation
#   nvidia/nemotron-3-super-120b-a12b:free                                  - Slow model
#   google/gemma-4-26b-a4b-it:free                                          - No response
#   google/gemma-4-31b-it:free                                              - No response
#  gemini-3.1-flash-lite-preview                                            - Passing normal tests                                                          google api    

LMSTUDIO_BASE_URL=http://127.0.0.1:11434/v1
LMSTUDIO_MODEL=qwen/qwen3-4b-2507

# ────── Model tested ( GITLAB / GITHUB ) ─────────────────────────────────────
REMOTE_REPOSITORY=GITLAB

# ── GitHub (REQUIRED) ────────────────────────────────────────────────────────
# Create a PAT with repo + issues scopes:
# https://github.com/settings/tokens/new
GITHUB_TOKEN=   
GITHUB_REPOSITORY=

# ── GitLab (REQUIRED) ─────────────────────────────────────────────────────────
# Create a PAT with repo + issues scopers:
# https://gitlab.com/-/user_settings/personal_access_tokens
GITLAB_REPOSITORY=

# __ Max token limit for all llm (Default at 8192 for online llms)_____________
MAX_TOKEN=6000 

# Interfacing the whole LLM config with MODEL_PROFILE variable present inside the src/config/llm.py
# Possible values : LOW(2B to 4B) - STANDARD(7B to 14B) - HIGH(27 to 30B) - CUSTOM
MODEL_PROFILE=HIGH

# Add custom values here
MAX_CONTEXT=12000
MAX_TOOL_OUT=6000
MAX_HISTORY=20
MAX_FILES=80
MAX_SPEC=6000
MAX_TEST_OUT=3000
SYSTEM_VERBOSE=true

# The app automatically resolves its own GitHub username from the token.

# ── LangSmith (OPTIONAL — observability only) ────────────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_api_key_here
# LANGCHAIN_PROJECT=ai-dev-system


# Host ip of the project
IP_ADDRESS = 0.0.0.0

# Domain name, for later definition - Current value will be null
DOMAIN_NAME =
